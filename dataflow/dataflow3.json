{
	"name": "dataflow3",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_adls_datafiles_employee",
						"type": "DatasetReference"
					},
					"name": "srcEmployee"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "ls_azSQL_DATASTORE",
						"type": "LinkedServiceReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "sort1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          EmployeeNO as short,",
				"          Ename as string,",
				"          Job as string,",
				"          Hiredate as date,",
				"          DepartmentNO as short,",
				"          Sal as double,",
				"          Comm as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> srcEmployee",
				"srcEmployee sort(asc(DepartmentNO, true),",
				"     desc(Sal, true),",
				"     partitionBy('hash', 1)) ~> sort1",
				"sort1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          EmployeeNO as integer,",
				"          Ename as string,",
				"          Job as string,",
				"          Hiredate as date,",
				"          DepartmentNO as integer,",
				"          Sal as decimal(19,4),",
				"          Comm as decimal(19,4)",
				"     ),",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo',",
				"     tableName: 'employee1',",
				"     insertable: true,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: false,",
				"     truncate: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          EmployeeNO,",
				"          Ename,",
				"          Job,",
				"          Sal,",
				"          Comm,",
				"          DepartmentNO,",
				"          Hiredate",
				"     )) ~> sink1"
			]
		}
	}
}