{
	"name": "dataflow2",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_adls_datafiles_employee",
						"type": "DatasetReference"
					},
					"name": "srcEmployee"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "ls_azSQL_DATASTORE",
						"type": "LinkedServiceReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          EmployeeNO as short,",
				"          Ename as string,",
				"          Job as string,",
				"          Hiredate as date,",
				"          DepartmentNO as short,",
				"          Sal as double,",
				"          Comm as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> srcEmployee",
				"srcEmployee derive(Year = year(Hiredate),",
				"          Month = case(\r",
				"    month(Hiredate)==1, 'Jan',\r",
				"    month(Hiredate)==2, 'Feb',\r",
				"    month(Hiredate)==3, 'Mar',\r",
				"    month(Hiredate)==4, 'Apr',\r",
				"    month(Hiredate)==5, 'May',\r",
				"    month(Hiredate)==6, 'Jun',\r",
				"    month(Hiredate)==7, 'Jul',\r",
				"    month(Hiredate)==8, 'Aug',\r",
				"    month(Hiredate)==9, 'Sep', 'Others')\r",
				") ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          empno as integer,",
				"          ename as string,",
				"          job as string,",
				"          year as integer,",
				"          monthname as string,",
				"          salary as decimal(19,4),",
				"          comm as decimal(19,4)",
				"     ),",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo',",
				"     tableName: 'employee',",
				"     insertable: true,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          empno = EmployeeNO,",
				"          ename = Ename,",
				"          job = Job,",
				"          salary = Sal,",
				"          comm = Comm,",
				"          year = Year,",
				"          monthname = Month",
				"     )) ~> sink1"
			]
		}
	}
}